# --- 민감/런타임 데이터 (절대 커밋 금지) ---
data/sessions/          # DPAPI로 암호화된 네이버 로그인 쿠키
data/*.db               # 크롤된 게시글/댓글 DB
data/
*.session

# 대시보드 로그인 자격증명 (비밀번호)
config/dashboard_auth.json
# SSO 공유 시크릿 (대시보드 ↔ 다른 앱 통합 로그인)
config/sso_secret.txt

# 구글 서비스계정 / 인증
credentials.json
token.json
*-*.json.key
service_account*.json

# 참고용 샘플 프로그램 (제3자 컴파일 바이너리 — 커밋 제외)
샘플 프로그램/
*.exe
*.dll
*.mp4

# Python
__pycache__/
*.pyc
.venv/
venv/
.env

# OS / IDE
Thumbs.db
.DS_Store
.idea/
.vscode/
